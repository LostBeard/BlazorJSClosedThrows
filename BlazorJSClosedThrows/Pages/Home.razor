@page "/"
@using SpawnDev.BlazorJS;
@using SpawnDev.BlazorJS.Toolbox;
@using SpawnDev.BlazorJS.JSObjects;
@inject BlazorJSRuntime JS;

<PageTitle>LostBeard/SpawnDev.BlazorJS#62</PageTitle>

<h3>LostBeard/SpawnDev.BlazorJS#62</h3>

<p>
    Demo issue #62. Accessing "closed" property on a cross origin window via Blazor Wasm throws an exception.
</p>
<button disabled="@_busy" class="btn btn-primary" @onclick="OpenCrossOriginWindow">Open Cross-Origin Window</button>

<h4>Log</h4>
<p>@((MarkupString)_logText.Replace(Environment.NewLine, "<br />"))</p>

@code {
    string _logText = "";
    bool _busy = false;

    public async Task OpenCrossOriginWindow()
    {
        _busy = true;
        Log($"WithoutCrossOriginWindow2(): opening popup");
        StateHasChanged();

        var url = "https://www.googleapis.com/auth/youtube";

        var window = new Window();
        var popup = window.Open(url, "Google Auth", "height=800,width=1200");

        if (popup is not null)
        {
            // Close the popup in 5 seconds to automate the test
            _ = Async.RunAsync(async () =>
            {
                await Task.Delay(5000);
                try
                {
                    popup!.Close();
                }
                catch { }
            });

            try
            {
                while (!popup.Closed)
                    await Task.Delay(1000);
                Log($"WithoutCrossOriginWindow2(): popup was closed");
            }
            catch (Exception ex)
            {
                Log($"WithoutCrossOriginWindow2(): popup closed access exception: {ex.ToString()}");
            }
        }
        else
        {
            Log($"WithoutCrossOriginWindow2(): popup was null");
        }

        _busy = false;
        StateHasChanged();
    }

    void Log(params string?[] msg)
    {
        _logText = _logText + string.Join(Environment.NewLine, msg) + Environment.NewLine;
        StateHasChanged();
    }
}
